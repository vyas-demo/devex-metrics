{
  "name": "devex-metrics",
  "version": "1.0.0",
  "description": "DevEx reporting and dashboarding for GitHub repos and organizations",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "save-fixture": "npm run build && node dist/save-fixture.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "mutation": "stryker run",
    "mutation:ci": "stryker run --reporters json,clear-text"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/devex-metrics/devex-metrics.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "bugs": {
    "url": "https://github.com/devex-metrics/devex-metrics/issues"
  },
  "homepage": "https://github.com/devex-metrics/devex-metrics#readme",
  "dependencies": {
    "@octokit/auth-app": "^8.2.0",
    "@octokit/plugin-throttling": "^11.0.3",
    "@octokit/rest": "^22.0.1",
    "typescript": "^6.0.3"
  },
  "devDependencies": {
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^25.6.0",
    "jsdom": "^29.1.1",
    "vitest": "^4.1.5"
  }
}
